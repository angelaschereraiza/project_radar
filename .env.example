# ─── Simap API ───────────────────────────────────────────────────────────────
SIMAP_BASE_URL=https://www.simap.ch

# How many days back to scan for new tenders (1 = daily run, 7 = weekly run)
LOOKBACK_DAYS=1

# ─── Ollama (local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ─── SMTP / Email ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=angela.scherer@aiza.ch
SMTP_PASSWORD=your-password

MAIL_FROM=angela.scherer@aiza.ch
MAIL_TO=angela.scherer@aiza.ch

# ── Gmail example ─────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASSWORD=your-app-password   # App password — not your regular password
#                                   # Create one at: myaccount.google.com/apppasswords

# ── Proton Mail Bridge (local) ────────────────────────────────────────────────
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_USER=angela.scherer@aiza.ch
# SMTP_PASSWORD=bridge-password
